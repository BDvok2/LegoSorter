# Brickognize API
API_URL=https://api.brickognize.com/predict/

# Test image path
IMAGE_FILE=assets/test.jpg

# Detection settings
CONFIDENCE_THRESHOLD=0.5
REQUEST_TIMEOUT=5
KMEANS_CLUSTERS=3
MIN_VALID_PIXELS=50

# Cerebras/LLM settings
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b
CEREBRAS_API_BASE=https://api.cerebras.ai/v1
